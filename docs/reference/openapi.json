{
  "openapi": "3.1.0",
  "info": {
    "title": "modern-pki lifecycle and operator API",
    "version": "0.1.0",
    "description": "Lifecycle, operator, distribution, and local ACME management APIs exposed by modern-pki-service. RFC 8555 public ACME protocol endpoints are tracked in acme-rfc8555-conformance.md."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "identities"},
    {"name": "issuers"},
    {"name": "certificate-profiles"},
    {"name": "enrollments"},
    {"name": "certificates"},
    {"name": "crl"},
    {"name": "ocsp"},
    {"name": "operator"},
    {"name": "outbox"},
    {"name": "notifications"},
    {"name": "api-keys"},
    {"name": "audit"},
    {"name": "trust"},
    {"name": "acme-management"}
  ],
  "paths": {
    "/identities": {
      "get": {
        "tags": ["identities"],
        "operationId": "listIdentities",
        "responses": {"200": {"$ref": "#/components/responses/IdentityList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["identities"],
        "operationId": "createIdentity",
        "requestBody": {"$ref": "#/components/requestBodies/IdentityCreate"},
        "responses": {"201": {"$ref": "#/components/responses/Identity"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/identities/{id}": {
      "get": {
        "tags": ["identities"],
        "operationId": "getIdentity",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Identity"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers": {
      "post": {
        "tags": ["issuers"],
        "operationId": "createIssuer",
        "requestBody": {"$ref": "#/components/requestBodies/IssuerCreate"},
        "responses": {"201": {"$ref": "#/components/responses/Issuer"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers/{id}/chain": {
      "get": {
        "tags": ["issuers"],
        "operationId": "getIssuerChain",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/IssuerList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers/{id}/crl": {
      "get": {
        "tags": ["crl"],
        "operationId": "getLatestIssuerCRL",
        "security": [],
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"description": "Latest issuer CRL PEM", "content": {"application/pem-certificate-chain": {"schema": {"type": "string"}}}}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers/{id}/ocsp-responders": {
      "get": {
        "tags": ["ocsp"],
        "operationId": "listOCSPResponders",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/OCSPResponderList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["ocsp"],
        "operationId": "createOCSPResponder",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/OCSPResponderCreate"},
        "responses": {"201": {"$ref": "#/components/responses/OCSPResponder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers/{id}/ocsp-responders/rotate": {
      "post": {
        "tags": ["ocsp"],
        "operationId": "rotateOCSPResponder",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/OCSPResponderCreate"},
        "responses": {"201": {"$ref": "#/components/responses/OCSPResponder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/issuers/{id}/ocsp-responders/{responderID}/disable": {
      "post": {
        "tags": ["ocsp"],
        "operationId": "disableOCSPResponder",
        "parameters": [{"$ref": "#/components/parameters/id"}, {"$ref": "#/components/parameters/responderID"}],
        "responses": {"200": {"$ref": "#/components/responses/OCSPResponder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificate-profiles": {
      "get": {
        "tags": ["certificate-profiles"],
        "operationId": "listCertificateProfiles",
        "responses": {"200": {"$ref": "#/components/responses/CertificateProfileList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["certificate-profiles"],
        "operationId": "createCertificateProfile",
        "requestBody": {"$ref": "#/components/requestBodies/CertificateProfileCreate"},
        "responses": {"201": {"$ref": "#/components/responses/CertificateProfile"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificate-profiles/{id}": {
      "get": {
        "tags": ["certificate-profiles"],
        "operationId": "getCertificateProfile",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/CertificateProfile"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/enrollments": {
      "get": {
        "tags": ["enrollments"],
        "operationId": "listEnrollments",
        "responses": {"200": {"$ref": "#/components/responses/EnrollmentList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["enrollments"],
        "operationId": "createEnrollment",
        "requestBody": {"$ref": "#/components/requestBodies/EnrollmentCreate"},
        "responses": {"201": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/enrollments/{id}": {
      "get": {
        "tags": ["enrollments"],
        "operationId": "getEnrollment",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/enrollments/{id}/approve": {
      "post": {
        "tags": ["enrollments"],
        "operationId": "approveEnrollment",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/enrollments/{id}/reject": {
      "post": {
        "tags": ["enrollments"],
        "operationId": "rejectEnrollment",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates": {
      "get": {
        "tags": ["certificates"],
        "operationId": "listCertificates",
        "parameters": [{"$ref": "#/components/parameters/expiresWithinDays"}, {"$ref": "#/components/parameters/limit"}, {"$ref": "#/components/parameters/offset"}],
        "responses": {"200": {"$ref": "#/components/responses/CertificateList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["certificates"],
        "operationId": "issueCertificate",
        "requestBody": {"$ref": "#/components/requestBodies/CertificateIssue"},
        "responses": {"201": {"$ref": "#/components/responses/Certificate"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}": {
      "get": {
        "tags": ["certificates"],
        "operationId": "getCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Certificate"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}/revoke": {
      "post": {
        "tags": ["certificates"],
        "operationId": "revokeCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/CertificateRevoke"},
        "responses": {"200": {"$ref": "#/components/responses/Certificate"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}/suspend": {
      "post": {
        "tags": ["certificates"],
        "operationId": "suspendCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Certificate"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}/resume": {
      "post": {
        "tags": ["certificates"],
        "operationId": "resumeCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/Certificate"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}/renew": {
      "post": {
        "tags": ["certificates"],
        "operationId": "renewCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/CertificateReplacement"},
        "responses": {"201": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/{id}/reissue": {
      "post": {
        "tags": ["certificates"],
        "operationId": "reissueCertificate",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/CertificateReplacement"},
        "responses": {"201": {"$ref": "#/components/responses/Enrollment"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/certificates/expiration-scan": {
      "post": {
        "tags": ["operator"],
        "operationId": "scanCertificateExpirations",
        "requestBody": {"$ref": "#/components/requestBodies/ExpirationScan"},
        "responses": {"200": {"$ref": "#/components/responses/ExpirationScan"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/crls": {
      "post": {
        "tags": ["crl"],
        "operationId": "publishCRL",
        "requestBody": {"$ref": "#/components/requestBodies/CRLPublish"},
        "responses": {"201": {"$ref": "#/components/responses/CRLPublication"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/crls/{id}": {
      "get": {
        "tags": ["crl"],
        "operationId": "getCRLPublication",
        "security": [],
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/CRLPublication"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/ocsp": {
      "post": {
        "tags": ["ocsp"],
        "operationId": "respondOCSP",
        "security": [],
        "requestBody": {"required": true, "content": {"application/ocsp-request": {"schema": {"type": "string", "contentEncoding": "base64"}}}},
        "responses": {"200": {"description": "OCSP response DER", "content": {"application/ocsp-response": {"schema": {"type": "string", "contentEncoding": "base64"}}}}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/operator/certificate-inventory": {
      "get": {
        "tags": ["operator"],
        "operationId": "listCertificateInventory",
        "parameters": [
          {"$ref": "#/components/parameters/owner"},
          {"$ref": "#/components/parameters/team"},
          {"$ref": "#/components/parameters/service"},
          {"$ref": "#/components/parameters/environment"},
          {"$ref": "#/components/parameters/issuer"},
          {"$ref": "#/components/parameters/profile"},
          {"$ref": "#/components/parameters/revocationState"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"}
        ],
        "responses": {"200": {"$ref": "#/components/responses/CertificateInventoryList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/operator/expiry-slo": {
      "get": {
        "tags": ["operator"],
        "operationId": "getExpirySLO",
        "responses": {"200": {"$ref": "#/components/responses/ExpirySLO"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/notification-endpoints": {
      "get": {
        "tags": ["notifications"],
        "operationId": "listNotificationEndpoints",
        "responses": {"200": {"$ref": "#/components/responses/NotificationEndpointList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["notifications"],
        "operationId": "createNotificationEndpoint",
        "requestBody": {"$ref": "#/components/requestBodies/NotificationEndpointCreate"},
        "responses": {"201": {"$ref": "#/components/responses/NotificationEndpoint"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/notification-endpoints/{id}/disable": {
      "post": {
        "tags": ["notifications"],
        "operationId": "disableNotificationEndpoint",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/NotificationEndpoint"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/outbox/messages": {
      "get": {
        "tags": ["outbox"],
        "operationId": "listOutboxMessages",
        "parameters": [{"$ref": "#/components/parameters/outboxStatus"}],
        "responses": {"200": {"$ref": "#/components/responses/OutboxMessageList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/outbox/messages/{id}/retry": {
      "post": {
        "tags": ["outbox"],
        "operationId": "retryOutboxMessage",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/OutboxMessage"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/outbox/messages/dead-letter/replay": {
      "post": {
        "tags": ["outbox"],
        "operationId": "replayDeadLetterOutboxMessages",
        "requestBody": {"$ref": "#/components/requestBodies/DeadLetterReplay"},
        "responses": {"200": {"$ref": "#/components/responses/DeadLetterReplay"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/api-keys": {
      "get": {
        "tags": ["api-keys"],
        "operationId": "listAPIKeys",
        "responses": {"200": {"$ref": "#/components/responses/APIKeyList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["api-keys"],
        "operationId": "createAPIKey",
        "requestBody": {"$ref": "#/components/requestBodies/APIKeyCreate"},
        "responses": {"201": {"$ref": "#/components/responses/APIKeyWithToken"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/api-keys/{id}/rotate": {
      "post": {
        "tags": ["api-keys"],
        "operationId": "rotateAPIKey",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"201": {"$ref": "#/components/responses/APIKeyWithToken"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/api-keys/{id}/disable": {
      "post": {
        "tags": ["api-keys"],
        "operationId": "disableAPIKey",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/APIKey"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/audit-events": {
      "get": {
        "tags": ["audit"],
        "operationId": "listAuditEvents",
        "parameters": [
          {"$ref": "#/components/parameters/auditActor"},
          {"$ref": "#/components/parameters/auditAction"},
          {"$ref": "#/components/parameters/auditResourceType"},
          {"$ref": "#/components/parameters/auditResourceID"},
          {"$ref": "#/components/parameters/auditFrom"},
          {"$ref": "#/components/parameters/auditTo"},
          {"$ref": "#/components/parameters/auditSort"},
          {"$ref": "#/components/parameters/limit"},
          {"$ref": "#/components/parameters/offset"}
        ],
        "responses": {"200": {"$ref": "#/components/responses/AuditEventList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/audit-events/retention/prune": {
      "post": {
        "tags": ["audit"],
        "operationId": "pruneAuditEvents",
        "requestBody": {"$ref": "#/components/requestBodies/AuditRetentionPrune"},
        "responses": {"200": {"$ref": "#/components/responses/AuditRetentionPrune"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/audit-events/repair/issuance": {
      "post": {
        "tags": ["audit"],
        "operationId": "repairIssuanceAuditEvents",
        "responses": {"200": {"$ref": "#/components/responses/AuditRepair"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/trust/anchors": {
      "get": {
        "tags": ["trust"],
        "operationId": "listTrustAnchors",
        "responses": {"200": {"$ref": "#/components/responses/IssuerList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/accounts": {
      "get": {
        "tags": ["acme-management"],
        "operationId": "listACMEAccounts",
        "responses": {"200": {"$ref": "#/components/responses/ACMEAccountList"}, "default": {"$ref": "#/components/responses/Error"}}
      },
      "post": {
        "tags": ["acme-management"],
        "operationId": "createACMEAccount",
        "requestBody": {"$ref": "#/components/requestBodies/ACMEAccountCreate"},
        "responses": {"201": {"$ref": "#/components/responses/ACMEAccount"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/orders": {
      "post": {
        "tags": ["acme-management"],
        "operationId": "createACMEOrder",
        "requestBody": {"$ref": "#/components/requestBodies/ACMEOrderCreate"},
        "responses": {"201": {"$ref": "#/components/responses/ACMEOrder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/orders/{id}": {
      "get": {
        "tags": ["acme-management"],
        "operationId": "getACMEOrder",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/ACMEOrder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/orders/{id}/authorizations": {
      "get": {
        "tags": ["acme-management"],
        "operationId": "listACMEAuthorizations",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/ACMEAuthorizationList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/orders/{id}/finalize": {
      "post": {
        "tags": ["acme-management"],
        "operationId": "finalizeACMEOrder",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "requestBody": {"$ref": "#/components/requestBodies/ACMEOrderFinalize"},
        "responses": {"200": {"$ref": "#/components/responses/ACMEOrder"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/authorizations/{id}/challenges": {
      "get": {
        "tags": ["acme-management"],
        "operationId": "listACMEChallenges",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/ACMEChallengeList"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    },
    "/acme/challenges/{id}/complete": {
      "post": {
        "tags": ["acme-management"],
        "operationId": "completeACMEChallenge",
        "parameters": [{"$ref": "#/components/parameters/id"}],
        "responses": {"200": {"$ref": "#/components/responses/ACMEChallenge"}, "default": {"$ref": "#/components/responses/Error"}}
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "id": {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}},
      "responderID": {"name": "responderID", "in": "path", "required": true, "schema": {"type": "string"}},
      "limit": {"name": "limit", "in": "query", "schema": {"type": "integer", "minimum": 1}},
      "offset": {"name": "offset", "in": "query", "schema": {"type": "integer", "minimum": 0}},
      "expiresWithinDays": {"name": "expires_within_days", "in": "query", "schema": {"type": "integer", "minimum": 1}},
      "owner": {"name": "owner", "in": "query", "schema": {"type": "string"}},
      "team": {"name": "team", "in": "query", "schema": {"type": "string"}},
      "service": {"name": "service", "in": "query", "schema": {"type": "string"}},
      "environment": {"name": "environment", "in": "query", "schema": {"type": "string"}},
      "issuer": {"name": "issuer", "in": "query", "schema": {"type": "string"}},
      "profile": {"name": "profile", "in": "query", "schema": {"type": "string"}},
      "revocationState": {"name": "revocation_state", "in": "query", "schema": {"type": "string"}},
      "auditActor": {"name": "actor", "in": "query", "schema": {"type": "string"}},
      "auditAction": {"name": "action", "in": "query", "schema": {"type": "string"}},
      "auditResourceType": {"name": "resource_type", "in": "query", "schema": {"type": "string"}},
      "auditResourceID": {"name": "resource_id", "in": "query", "schema": {"type": "string"}},
      "auditFrom": {"name": "from", "in": "query", "schema": {"type": "string", "format": "date-time"}},
      "auditTo": {"name": "to", "in": "query", "schema": {"type": "string", "format": "date-time"}},
      "auditSort": {"name": "sort", "in": "query", "schema": {"type": "string", "enum": ["asc", "desc"]}},
      "outboxStatus": {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["pending", "processing", "completed", "failed", "dead_letter"]}}
    },
    "requestBodies": {
      "IdentityCreate": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IdentityCreate"}}}},
      "IssuerCreate": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/IssuerCreate"}}}},
      "OCSPResponderCreate": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OCSPResponderCreate"}}}},
      "CertificateProfileCreate": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CertificateProfileCreate"}}}},
      "EnrollmentCreate": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EnrollmentCreate"}}}},
      "CertificateIssue": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["enrollment_id"], "properties": {"enrollment_id": {"type": "string"}}}}}},
      "CertificateRevoke": {"required": false, "content": {"application/json": {"schema": {"type": "object", "properties": {"reason": {"type": "string"}, "force": {"type": "boolean"}}}}}},
      "CertificateReplacement": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["csr_pem"], "properties": {"csr_pem": {"type": "string"}, "requested_not_after": {"type": "string", "format": "date-time"}}}}}},
      "ExpirationScan": {"required": false, "content": {"application/json": {"schema": {"type": "object", "properties": {"warning_window_seconds": {"type": "integer"}, "limit": {"type": "integer"}}}}}},
      "CRLPublish": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["issuer_id"], "properties": {"issuer_id": {"type": "string"}}}}}},
